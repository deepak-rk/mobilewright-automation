{
  "name": "mobilewright-automation",
  "version": "1.0.0",
  "description": "Cucumber-based iOS and Android automation framework using mobilewright",
  "private": true,
  "scripts": {
    "bddgen": "bddgen",
    "test": "npm run bddgen && mobilewright test",
    "test:ios": "npm run bddgen && mobilewright test --project ios",
    "test:android": "npm run bddgen && mobilewright test --project android",
    "test:parallel": "npm run bddgen && mobilewright test --workers 4",
    "test:tag": "npm run bddgen && cross-env-shell mobilewright test --grep \"$TAG\"",
    "report:full": "allure generate allure-results --clean -o allure-report && allure open allure-report",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report:single": "mobilewright show-report",
    "install:agent": "mobilewright install",
    "install:agent:force": "mobilewright install --force",
    "devices": "mobilewright devices",
    "doctor": "mobilewright doctor",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "clean": "rimraf .features-gen test-results reports allure-results allure-report"
  },
  "dependencies": {
    "@mobilewright/test": "^0.0.33",
    "dotenv": "^16.4.5",
    "mobilewright": "^0.0.33"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "allure-commandline": "^2.29.0",
    "allure-playwright": "^3.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "playwright-bdd": "^7.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  }
}

# ─── iOS ──────────────────────────────────────────────────────────────────────
# UDID of the connected real device (run: mobilewright devices)
IOS_UDID=00008101-000XXXXXXXXX

# Human-readable device name (used as fallback if UDID not specified)
IOS_DEVICE_NAME=iPhone 15 Pro

# Platform version (optional — mobilewright auto-detects if omitted)
IOS_PLATFORM_VERSION=17.0

# Absolute or project-relative path to the .ipa file
IOS_APP=./builds/MyApp.ipa

# Bundle identifier of the app
IOS_BUNDLE_ID=com.example.myapp

# ─── Android ──────────────────────────────────────────────────────────────────
# ADB device serial (run: adb devices)
ANDROID_DEVICE=R3CN10XXXXX

# Human-readable device name (used as fallback if ANDROID_DEVICE not specified)
ANDROID_DEVICE_NAME=Pixel 8

# Platform version (optional — auto-detected if omitted)
ANDROID_PLATFORM_VERSION=14

# Absolute or project-relative path to the .apk file
ANDROID_APP=./builds/MyApp.apk

# Package name of the app
ANDROID_PACKAGE=com.example.myapp

# ─── CI ───────────────────────────────────────────────────────────────────────
# Set to any non-empty value in CI pipelines to enable retries
# CI=true
